          ]
        }
      },
      "response": []
    },
    {
      "name": "Register Geumsangmall Front Client",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "X-Admin-Secret",
            "value": "{{adminSecret}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"clientId\": \"geumsangmall-front\",\n  \"clientSecret\": \"front-secret\",\n  \"systemCode\": \"GEUMSANGMALL\",\n  \"callSource\": \"DMZ_FRONT\",\n  \"active\": true,\n  \"scopes\": [\"api.read\"],\n  \"description\": \"금상몰 프론트 호출용\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/admin/partner-clients",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "admin",
            "partner-clients"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Issue Partner Token",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('token issued', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "var json = pm.response.json();",
              "if (json.accessToken) {",
              "  pm.environment.set('partnerAccessToken', json.accessToken);",
              "}",
              "if (json.refreshToken) {",
              "  pm.environment.set('refreshToken', json.refreshToken);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"clientId\": \"geumsangmall-front\",\n  \"clientSecret\": \"{{geumsangmallClientSecret}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/internal/token",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "internal",
            "token"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Refresh Partner Token",
      "request": {
