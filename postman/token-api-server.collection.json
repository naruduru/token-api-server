{
  "info": {
    "_postman_id": "8d33ff2f-cabc-4ef1-b3cb-b4ac8b2326fd",
    "name": "token-api-server",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Public Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/public/health",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "public",
            "health"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Register Internal System Client",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "X-Admin-Secret",
            "value": "{{adminSecret}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"clientId\": \"intranet-batch\",\n  \"clientSecret\": \"internal-secret\",\n  \"active\": true,\n  \"channel\": \"INTERNAL_SYSTEM\",\n  \"systemName\": \"order-sync-server\",\n  \"scopes\": [\"batch.read\", \"batch.write\"]\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/admin/partner-clients",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "admin",
            "partner-clients"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Issue Internal System Token",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('token issued', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "var json = pm.response.json();",
              "if (json.accessToken) {",
              "  pm.environment.set('internalAccessToken', json.accessToken);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"clientId\": \"intranet-batch\",\n  \"clientSecret\": \"internal-secret\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/internal/token",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "internal",
            "token"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Internal Ping",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{internalAccessToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/internal/ping",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "internal",
            "ping"
          ]
        }
      },
      "response": []
    }
  ]
}
